# Template for `secrets/demo-secrets.sops.yaml`. NOT USED DIRECTLY — copy
# this file, edit values, then encrypt with SOPS. Never commit an unencrypted
# `secrets/demo-secrets.yaml` — the repo's .gitignore blocks the plaintext form
# but SOPS-encrypted `*.sops.yaml` files ARE safe to commit.
#
# One-time bootstrap (per operator laptop):
#   brew install sops age
#   age-keygen -o ~/.config/sops/age/keys.txt
#   # Copy the printed public key into .sops.yaml
#   echo 'export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt' >> ~/.zshrc
#   source ~/.zshrc
#
# One-time bootstrap (per demo repo, after .sops.yaml has your public key):
#   cp secrets/demo-secrets.sops.yaml.example secrets/demo-secrets.sops.yaml
#   # Edit values (they're plaintext at this point).
#   sops --encrypt --in-place secrets/demo-secrets.sops.yaml
#   git add secrets/demo-secrets.sops.yaml && git commit -m "bootstrap demo secrets"
#
# To edit values later:  sops secrets/demo-secrets.sops.yaml  (opens $EDITOR)
# To rotate a value:     same command; edit; save.  Then git commit.

postgres-mainframe-proxy-auth:
  username: payments
  password: payments-pw-replace-me

mariadb-analytics-auth:
  username: payments
  password: payments-pw-replace-me
  root_password: root-pw-replace-me

mainframe-to-gg-debezium-auth:
  # Username/password must match the role the Postgres init script creates
  # (see 10-replication-user.sql).
  username: debezium
  password: debezium-password-replace-me

gg-to-postgres-jdbc-auth:
  # Credentials the GG→Postgres write-through JDBC sink connector uses.
  # Must match postgres-mainframe-proxy-auth (same DB, same user).
  username: payments
  password: payments-pw-replace-me

gg-to-mariadb-jdbc-auth:
  # Credentials the GG→MariaDB write-through JDBC sink connector uses.
  # Must match mariadb-analytics-auth (same DB, same user).
  username: payments
  password: payments-pw-replace-me
